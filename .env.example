# --- LLM ---
# Cloud (recommended default for voice latency)
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the Claude engine
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Engine selection ---
# STT_ENGINE: whisper (local) | deepgram (cloud)
STT_ENGINE=whisper
# LLM_ENGINE: claude (cloud) | ollama (local)
LLM_ENGINE=ollama
# TTS_ENGINE: say (macOS built-in) | kokoro (local) | elevenlabs (cloud)
TTS_ENGINE=kokoro

# --- Local engine config ---
# Whisper model name for nodejs-whisper (base.en is fast + good enough)
WHISPER_MODEL=base.en
# Ollama model (requires: ollama pull <model>)
OLLAMA_MODEL=llama3.2
# Kokoro voice id
KOKORO_VOICE=af_heart

# --- Cloud engine config (optional) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Capture tuning ---
# End-of-utterance silence in ms
SILENCE_MS=1200
# RMS threshold (0-32767) below which a frame counts as silence
SILENCE_THRESHOLD=500
